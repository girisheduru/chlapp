# Firebase (optional — for Sign in with Google)
# Copy to .env and fill from Firebase Console > Project settings > General > Your apps > Web app config
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
# VITE_FIREBASE_PROJECT_ID=your-project-id
# VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
# VITE_FIREBASE_MESSAGING_SENDER_ID=
# VITE_FIREBASE_APP_ID=
#
# Backend API base URL (no trailing slash). Embedded at `vite build` time.
# Local: set in .env or .env.local (copy this file to .env).
# Vercel: set the same variable in the Vercel project → Settings → Environment Variables (no .env file required there).
# VITE_API_URL=https://your-api.railway.app